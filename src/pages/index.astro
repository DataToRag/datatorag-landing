---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import IntegrationCard from "@/components/IntegrationCard.astro";
import { GITHUB_URL } from "@/lib/site-config";
import { formatDate } from "@/lib/site-config";
import { getCollection } from "astro:content";

const [featured, guides, useCases] = await Promise.all([
  getCollection("integrations", ({ data }) => data.featured),
  getCollection("guides", ({ data }) => !data.draft),
  getCollection("use-cases"),
]);

const latestGuides = guides
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  )
  .slice(0, 3);

const steps = [
  {
    number: "1",
    title: "Browse",
    description: "Find integrations for your industry and workflow",
  },
  {
    number: "2",
    title: "Install",
    description: "Follow our step-by-step guide — no coding required",
  },
  {
    number: "3",
    title: "Use",
    description: "Ask Claude to work with your connected apps",
  },
];
---

<BaseLayout title="MCP Integration Marketplace for Claude">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:py-36">
      <div class="mx-auto max-w-3xl text-center">
        <span
          class="mb-4 inline-block rounded-full border bg-muted px-3 py-1 text-xs font-medium text-muted-foreground"
        >
          Open Source MCP Integrations
        </span>
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
          Unlock Claude's full potential
          <span class="block text-muted-foreground">with integrations</span>
        </h1>
        <p class="mx-auto mt-6 max-w-2xl text-lg text-muted-foreground">
          Most people only use Claude for basic chat. Connect it to Slack,
          Google Drive, Salesforce, and more — and it becomes a real work
          assistant. No coding required.
        </p>
        <div
          class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <a
            href="/integrations"
            class="inline-flex h-11 items-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
          >
            Browse Integrations
          </a>
          <a
            href="/guides/what-is-mcp"
            class="inline-flex h-11 items-center rounded-md border px-6 text-sm font-medium transition-colors hover:bg-accent"
          >
            What is MCP?
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- What is MCP -->
  <section class="border-b py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-3xl text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          What is MCP?
        </h2>
        <p class="mt-4 text-muted-foreground">
          <strong>MCP (Model Context Protocol)</strong> lets Claude connect to the
          apps you already use. Think of it like installing apps on your phone — your
          phone works fine without them, but they make it way more useful. MCP integrations
          do the same for Claude.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-4xl gap-6 sm:grid-cols-3">
        <div class="rounded-lg border bg-card p-6 text-center">
          <div class="text-3xl">📧</div>
          <h3 class="mt-3 font-semibold">Read your emails</h3>
          <p class="mt-1 text-sm text-muted-foreground">
            Claude can check your inbox and draft replies
          </p>
        </div>
        <div class="rounded-lg border bg-card p-6 text-center">
          <div class="text-3xl">📁</div>
          <h3 class="mt-3 font-semibold">Search your docs</h3>
          <p class="mt-1 text-sm text-muted-foreground">
            Ask questions about files in Google Drive
          </p>
        </div>
        <div class="rounded-lg border bg-card p-6 text-center">
          <div class="text-3xl">☁️</div>
          <h3 class="mt-3 font-semibold">Manage your CRM</h3>
          <p class="mt-1 text-sm text-muted-foreground">
            Query Salesforce contacts and deals by asking
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Integrations -->
  <section class="border-b py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            Popular Integrations
          </h2>
          <p class="mt-2 text-muted-foreground">
            Get started with the most popular MCP integrations
          </p>
        </div>
        <a
          href="/integrations"
          class="hidden text-sm font-medium text-primary hover:underline sm:block"
        >
          View all →
        </a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          featured.map((i) => (
            <IntegrationCard
              id={i.id}
              name={i.data.name}
              description={i.data.description}
              icon={i.data.icon}
              difficulty={i.data.difficulty}
              setupTime={i.data.setupTime}
              industries={i.data.industries}
            />
          ))
        }
      </div>
      <a
        href="/integrations"
        class="mt-6 block text-center text-sm font-medium text-primary hover:underline sm:hidden"
      >
        View all integrations →
      </a>
    </div>
  </section>

  <!-- Industry Use Cases -->
  <section class="border-b py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          See what's possible for your industry
        </h2>
        <p class="mt-2 text-muted-foreground">
          Real examples of how teams in your field use Claude with integrations
        </p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          useCases.map((uc) => (
            <a
              href={`/use-cases/${uc.id}`}
              class="group rounded-lg border bg-card p-6 transition-colors hover:border-primary/30 hover:bg-accent/50"
            >
              <h3 class="text-lg font-semibold group-hover:text-primary">
                {uc.data.title}
              </h3>
              <p class="mt-2 text-sm text-muted-foreground">
                {uc.data.description}
              </p>
              <span class="mt-4 inline-block text-sm font-medium text-primary">
                Learn more →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="border-b py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          How it works
        </h2>
        <p class="mt-2 text-muted-foreground">
          Three simple steps. No coding required.
        </p>
      </div>
      <div class="mx-auto mt-10 grid max-w-3xl gap-8 sm:grid-cols-3">
        {
          steps.map((step) => (
            <div class="text-center">
              <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary text-lg font-bold text-primary-foreground">
                {step.number}
              </div>
              <h3 class="mt-4 text-lg font-semibold">{step.title}</h3>
              <p class="mt-1 text-sm text-muted-foreground">
                {step.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- For Developers -->
  <section class="border-b py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div
        class="mx-auto max-w-3xl rounded-lg border bg-card p-8 text-center sm:p-12"
      >
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          For Developers
        </h2>
        <p class="mt-4 text-muted-foreground">
          Every integration is open source. Fork them, contribute improvements,
          or use them as templates to build your own custom MCP extensions.
        </p>
        <div
          class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row"
        >
          <a
            href={GITHUB_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-10 items-center rounded-md bg-primary px-5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
          >
            View on GitHub
          </a>
          <a
            href="/guides"
            class="inline-flex h-10 items-center rounded-md border px-5 text-sm font-medium transition-colors hover:bg-accent"
          >
            Read the Docs
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Guides -->
  <section class="border-b py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            Latest Guides
          </h2>
          <p class="mt-2 text-muted-foreground">
            Learn what's possible and how to get started
          </p>
        </div>
        <a
          href="/guides"
          class="hidden text-sm font-medium text-primary hover:underline sm:block"
        >
          View all →
        </a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          latestGuides.map((guide) => (
            <a
              href={`/guides/${guide.id}`}
              class="group rounded-lg border bg-card p-5 transition-colors hover:border-primary/30 hover:bg-accent/50"
            >
              <span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">
                {guide.data.category}
              </span>
              <h3 class="mt-2 font-semibold group-hover:text-primary">
                {guide.data.title}
              </h3>
              <p class="mt-1 text-sm text-muted-foreground line-clamp-2">
                {guide.data.description}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          Ready to unlock Claude's full potential?
        </h2>
        <p class="mt-4 text-muted-foreground">
          Browse our integration marketplace and set up your first connection in
          minutes. No coding experience needed.
        </p>
        <a
          href="/integrations"
          class="mt-6 inline-flex h-11 items-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90"
        >
          Browse Integrations
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
