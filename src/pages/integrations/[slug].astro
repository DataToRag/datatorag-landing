---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const integrations = await getCollection("integrations");
  return integrations.map((integration) => ({
    params: { slug: integration.id },
    props: { integration },
  }));
}

const { integration } = Astro.props;
const { Content } = await render(integration);

const allIntegrations = await getCollection("integrations");
const related = allIntegrations
  .filter(
    (i) =>
      i.id !== integration.id &&
      i.data.industries.some((ind: string) =>
        integration.data.industries.includes(ind),
      ),
  )
  .slice(0, 3);
---

<BaseLayout
  title={integration.data.name}
  description={integration.data.description}
>
  <Header />

  <article class="py-10">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm text-muted-foreground">
        <a href="/integrations" class="hover:text-foreground">Integrations</a>
        <span class="mx-2">/</span>
        <span>{integration.data.name}</span>
      </nav>

      <!-- Header -->
      <div class="flex items-start gap-4">
        <span class="text-4xl">{integration.data.icon}</span>
        <div>
          <h1 class="text-3xl font-bold tracking-tight">
            {integration.data.name}
          </h1>
          <p class="mt-1 text-lg text-muted-foreground">
            {integration.data.description}
          </p>
        </div>
      </div>

      <!-- Meta -->
      <div class="mt-6 flex flex-wrap gap-2">
        <span class="rounded-full bg-muted px-3 py-1 text-xs font-medium">
          {integration.data.difficulty}
        </span>
        <span class="rounded-full bg-muted px-3 py-1 text-xs font-medium">
          {integration.data.setupTime} setup
        </span>
        {
          integration.data.industries.map((ind: string) => (
            <span class="rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
              {ind}
            </span>
          ))
        }
      </div>

      <!-- Compatibility -->
      <div class="mt-4 flex gap-3 text-sm text-muted-foreground">
        {
          integration.data.compatibility.claudeDesktop && (
            <span class="flex items-center gap-1">
              <svg
                class="h-4 w-4 text-green-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              Claude Desktop
            </span>
          )
        }
        {
          integration.data.compatibility.claudeCode && (
            <span class="flex items-center gap-1">
              <svg
                class="h-4 w-4 text-green-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              Claude Code
            </span>
          )
        }
        {
          integration.data.compatibility.claudeApi && (
            <span class="flex items-center gap-1">
              <svg
                class="h-4 w-4 text-green-600"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              Claude API
            </span>
          )
        }
      </div>

      <!-- Content -->
      <div class="prose prose-zinc mt-10 max-w-none dark:prose-invert">
        <Content />
      </div>

      <!-- GitHub CTA -->
      <div class="mt-10 rounded-lg border bg-muted/30 p-6">
        <h3 class="font-semibold">Open Source</h3>
        <p class="mt-1 text-sm text-muted-foreground">
          This integration is open source. View the code, report issues, or
          contribute on GitHub.
        </p>
        <a
          href={integration.data.repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-3 inline-flex h-9 items-center rounded-md border px-4 text-sm font-medium transition-colors hover:bg-accent"
        >
          View on GitHub →
        </a>
      </div>

      <!-- Related -->
      {
        related.length > 0 && (
          <div class="mt-12">
            <h2 class="text-xl font-bold">Related Integrations</h2>
            <div class="mt-4 grid gap-4 sm:grid-cols-3">
              {related.map((r) => (
                <a
                  href={`/integrations/${r.id}`}
                  class="group rounded-lg border bg-card p-4 transition-colors hover:border-primary/30 hover:bg-accent/50"
                >
                  <span class="text-xl">{r.data.icon}</span>
                  <h3 class="mt-2 font-semibold group-hover:text-primary">
                    {r.data.name}
                  </h3>
                  <p class="mt-1 text-xs text-muted-foreground line-clamp-2">
                    {r.data.description}
                  </p>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </article>

  <Footer />
</BaseLayout>
