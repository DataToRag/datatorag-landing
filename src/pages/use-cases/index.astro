---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { getCollection } from "astro:content";

const useCases = await getCollection("use-cases");
---

<BaseLayout
  title="Use Cases by Industry"
  description="See how teams in your industry use Claude with MCP integrations to get more done."
>
  <Header />

  <section class="border-b py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Use Cases by Industry
      </h1>
      <p class="mt-2 text-lg text-muted-foreground">
        See how teams in your industry use Claude with MCP integrations. Real
        examples, practical workflows.
      </p>
    </div>
  </section>

  <section class="py-10">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          useCases.map((uc) => (
            <a
              href={`/use-cases/${uc.id}`}
              class="group rounded-lg border bg-card p-6 transition-colors hover:border-primary/30 hover:bg-accent/50"
            >
              <h2 class="text-xl font-semibold group-hover:text-primary">
                {uc.data.title}
              </h2>
              <p class="mt-2 text-sm text-muted-foreground">
                {uc.data.description}
              </p>
              {uc.data.featuredIntegrations.length > 0 && (
                <p class="mt-3 text-xs text-muted-foreground">
                  <span class="font-medium">
                    {uc.data.featuredIntegrations.length} integrations
                  </span>{" "}
                  featured
                </p>
              )}
              <span class="mt-4 inline-block text-sm font-medium text-primary">
                Explore →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
