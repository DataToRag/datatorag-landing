---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import Header from "@/components/layout/Header.astro";
import Footer from "@/components/layout/Footer.astro";
import { getCollection } from "astro:content";

const guides = await getCollection("guides", ({ data }) => !data.draft);
const sorted = guides.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);

const categories = [...new Set(guides.map((g) => g.data.category))];
---

<BaseLayout
  title="Guides & Resources"
  description="Learn how to use Claude with MCP integrations. Tutorials, guides, and best practices."
>
  <Header />

  <section class="border-b py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Guides & Resources
      </h1>
      <p class="mt-2 text-lg text-muted-foreground">
        Learn what's possible with Claude and MCP integrations. From getting
        started to industry-specific workflows.
      </p>
    </div>
  </section>

  <section class="py-10">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <!-- Category filter -->
      <div class="mb-8 flex flex-wrap gap-2">
        {
          categories.map((cat) => (
            <span class="rounded-full border px-3 py-1 text-xs font-medium capitalize">
              {cat}
            </span>
          ))
        }
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          sorted.map((guide) => (
            <a
              href={`/guides/${guide.id}`}
              class="group rounded-lg border bg-card p-5 transition-colors hover:border-primary/30 hover:bg-accent/50"
            >
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-muted px-2 py-0.5 text-xs font-medium capitalize text-muted-foreground">
                  {guide.data.category}
                </span>
                <span class="rounded-full bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">
                  {guide.data.difficulty}
                </span>
              </div>
              <h2 class="mt-3 text-lg font-semibold group-hover:text-primary">
                {guide.data.title}
              </h2>
              <p class="mt-1 text-sm text-muted-foreground line-clamp-2">
                {guide.data.description}
              </p>
              <p class="mt-3 text-xs text-muted-foreground">
                {new Date(guide.data.pubDate).toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
                {guide.data.industry && (
                  <span> &middot; {guide.data.industry}</span>
                )}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
