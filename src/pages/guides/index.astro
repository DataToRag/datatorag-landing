---
import BaseLayout from "@/components/layout/BaseLayout.astro";
import PageHeader from "@/components/PageHeader.astro";
import { formatDate } from "@/lib/site-config";
import { getCollection } from "astro:content";

const guides = await getCollection("guides", ({ data }) => !data.draft);
const sorted = guides.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
);
---

<BaseLayout
  title="Guides & Resources"
  description="Learn how to use Claude with MCP integrations. Tutorials, guides, and best practices."
>
  <PageHeader
    title="Guides & Resources"
    description="Learn what's possible with Claude and MCP integrations. From getting started to industry-specific workflows."
  />

  <section class="py-10">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          sorted.map((guide) => (
            <a
              href={`/guides/${guide.id}`}
              class="group rounded-lg border bg-card p-5 transition-colors hover:border-primary/30 hover:bg-accent/50"
            >
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-muted px-2 py-0.5 text-xs font-medium capitalize text-muted-foreground">
                  {guide.data.category}
                </span>
                <span class="rounded-full bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground">
                  {guide.data.difficulty}
                </span>
              </div>
              <h2 class="mt-3 text-lg font-semibold group-hover:text-primary">
                {guide.data.title}
              </h2>
              <p class="mt-1 text-sm text-muted-foreground line-clamp-2">
                {guide.data.description}
              </p>
              <p class="mt-3 text-xs text-muted-foreground">
                {formatDate(guide.data.pubDate)}
                {guide.data.industry && (
                  <span> &middot; {guide.data.industry}</span>
                )}
              </p>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
