---
import { NAV_ITEMS, SITE_NAME, GITHUB_URL } from "@/lib/site-config";

const linkSections = [
  {
    title: "Product",
    links: NAV_ITEMS.map((item) => ({ label: item.label, href: item.href })),
  },
  {
    title: "Developers",
    links: [
      { label: "GitHub", href: GITHUB_URL },
      {
        label: "Contributing",
        href: `${GITHUB_URL}/blob/main/CONTRIBUTING.md`,
      },
      { label: "Documentation", href: "/guides" },
    ],
  },
];
---

<footer class="border-t bg-muted/30">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-4">
      <div class="sm:col-span-2 md:col-span-2">
        <a
          href="/"
          class="flex items-center gap-2 font-display text-lg font-bold"
        >
          <img src="/datatorag-logo.png" alt={SITE_NAME} class="h-8 w-8" />
          {SITE_NAME}
        </a>
        <p class="mt-3 max-w-sm text-sm text-muted-foreground">
          Discover and install MCP integrations that supercharge Claude for your
          industry. Open source, community-driven.
        </p>
      </div>
      {
        linkSections.map((section) => (
          <div>
            <h3 class="mb-3 font-display text-sm font-semibold">
              {section.title}
            </h3>
            <ul class="space-y-2">
              {section.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                    target={link.href.startsWith("http") ? "_blank" : undefined}
                    rel={
                      link.href.startsWith("http")
                        ? "noopener noreferrer"
                        : undefined
                    }
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="mt-10 border-t pt-6 text-center text-sm text-muted-foreground">
      &copy; {new Date().getFullYear()}
      {SITE_NAME}. All rights reserved.
    </div>
  </div>
</footer>
